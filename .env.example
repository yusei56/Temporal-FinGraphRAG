# Copy this file to `.env` and fill in local values.
# Never commit real API keys or proxy credentials.

# OpenAI-compatible API
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4.1-mini
LLM_JUDGE_MODEL=gpt-4.1-mini
TEMPERATURE=0
MAX_TOKENS=2000
LLM_TIMEOUT_SECONDS=120

# Neo4j. The password matches docker-compose.yaml by default.
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=12345678
NEO4J_MAX_POOL_SIZE=10
NEO4J_REFRESH_SCHEMA=false
